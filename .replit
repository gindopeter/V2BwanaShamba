modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true
integrations = ["javascript_log_in_with_replit:2.0.0", "github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ADK Agent Service"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "ADK Agent Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash adk_service/start.sh"
waitForPort = 8001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8001
externalPort = 3003

[[ports]]
localPort = 23636
externalPort = 8000

[[ports]]
localPort = 23637
externalPort = 80

[[ports]]
localPort = 23638
externalPort = 3000

[[ports]]
localPort = 23639
externalPort = 3001

[[ports]]
localPort = 23640
externalPort = 3002

[[ports]]
localPort = 23641
externalPort = 4200

[[ports]]
localPort = 23642
externalPort = 5173

[[ports]]
localPort = 23643
externalPort = 6000

[[ports]]
localPort = 23644
externalPort = 6800

[[ports]]
localPort = 23645
externalPort = 8080

[[ports]]
localPort = 23646
externalPort = 8081

[[ports]]
localPort = 23647
externalPort = 8099

[[ports]]
localPort = 23648
externalPort = 9000

[[ports]]
localPort = 24678
externalPort = 8008

[deployment]
deploymentTarget = "vm"
run = ["bash", "start_production.sh"]
build = ["npm", "run", "build"]

[userenv]

[userenv.production]
NODE_ENV = "production"

