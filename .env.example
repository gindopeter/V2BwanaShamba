# Required: Gemini API key for AI features
GEMINI_API_KEY="your-gemini-api-key"

# Required for production: Neon PostgreSQL connection string.
# Use the pooled connection string from Neon and require SSL.
DATABASE_URL="postgresql://user:password@ep-example-123456.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Required for production: Session encryption secret
SESSION_SECRET="generate-a-random-secret-here"

# Neon requires TLS. Leave this true (the server accepts Neon certificates).
DB_SSL="true"

# Optional: Internal token for ADK service authentication
ADK_INTERNAL_TOKEN="generate-a-random-token-here"

# Required for email OTP during registration — create an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# Firebase phone verification — the PRIMARY channel for phone OTP. Google
# delivers the SMS itself (no TCRA sender-ID registration needed). Setup:
#   1. Firebase console → create project → Authentication → enable "Phone".
#   2. Upgrade to the Blaze (pay-as-you-go) plan; SMS is billed per message.
#   3. Authentication → Settings → SMS region policy → allow Tanzania (+255).
#   4. Authentication → Settings → Authorized domains → add your production
#      domain (for this deployment: bwanashamba.com). If users also load the app
#      directly from the Cloud Run *.run.app URL, add that domain here too.
# The VITE_ values come from the Firebase web-app config (client-side, safe to
# expose). The server reuses VITE_FIREBASE_API_KEY to validate ID tokens via
# accounts:lookup (or set FIREBASE_API_KEY separately). Leave unset to fall
# back to WhatsApp-first verification.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project"
VITE_FIREBASE_APP_ID=""

# WhatsApp OTP via the Meta Cloud API — the fallback channel for phone
# verification when Firebase is unconfigured or a send fails. Requires a Cloud
# API number and an approved authentication template (see
# developers.facebook.com).
WA_PHONE_NUMBER_ID=""
WA_ACCESS_TOKEN=""
# Approved authentication-template name and its language code.
WA_TEMPLATE_NAME="otp_verification"
WA_TEMPLATE_LANG="en"
# Graph API version (optional, defaults to v21.0)
WA_API_VERSION="v21.0"

# SMS OTP via Africa's Talking — the fallback channel for phone verification.
# Keep OTP_SMS_ENABLED=false until a TCRA-registered sender ID is approved;
# unregistered-sender SMS is silently dropped by Tanzanian carriers.
OTP_SMS_ENABLED="false"
AT_USERNAME="sandbox"
AT_API_KEY="your-africastalking-api-key"
