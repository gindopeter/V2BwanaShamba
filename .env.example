# Required: Gemini API key for AI features
GEMINI_API_KEY="your-gemini-api-key"

# Required for production: PostgreSQL connection string
# For Cloud SQL: postgresql://user:password@localhost/bwanashamba?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL="postgresql://user:password@host:5432/bwanashamba"

# Required for production: Session encryption secret
SESSION_SECRET="generate-a-random-secret-here"

# Optional: Set to 'false' for Cloud SQL without SSL
DB_SSL="false"

# Optional: Internal token for ADK service authentication
ADK_INTERNAL_TOKEN="generate-a-random-token-here"

# Required for email OTP during registration — create an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# Required for SMS OTP during registration (Africa's Talking)
AT_USERNAME="sandbox"
AT_API_KEY="your-africastalking-api-key"
